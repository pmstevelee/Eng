      { "number": 17, "question_text": "I'm going out. If the phone ______, please answer it.", "options": { "A": "rang", "B": "rings", "C": "would ring", "D": "will ring" }, "correct_answer": "B" },
      { "number": 18, "question_text": "I ______ the car if I had the right tools.", "options": { "A": "can repair", "B": "repaired", "C": "could repair", "D": "will repair" }, "correct_answer": "C" },
      { "number": 19, "question_text": "If you mix yellow and blue, you ______ green.", "options": { "A": "get", "B": "got", "C": "would get", "D": "gets" }, "correct_answer": "A" },
      { "number": 20, "question_text": "I usually take some aspirin if I ______ a headache.", "options": { "A": "had", "B": "have", "C": "will have", "D": "would have" }, "correct_answer": "B" },
      { "number": 21, "question_text": "If flowers ______ enough water, they die.", "options": { "A": "don't get", "B": "get", "C": "didn't get", "D": "doesn't get" }, "correct_answer": "A" },
      { "number": 22, "question_text": "I ______ write to you if you don't give me your address.", "options": { "A": "can't", "B": "couldn't", "C": "wouldn't", "D": "didn't" }, "correct_answer": "A" },
      { "number": 23, "question_text": "Your cough ______ get better if you don't stop smoking.", "options": { "A": "will", "B": "would", "C": "won't", "D": "didn't" }, "correct_answer": "C" },
      { "number": 24, "question_text": "If he ______ a promise, he always keeps it.", "options": { "A": "made", "B": "would make", "C": "make", "D": "makes" }, "correct_answer": "D" },
      { "number": 25, "question_text": "If you ______ me, I'd have helped you.", "options": { "A": "asked", "B": "would ask", "C": "had asked", "D": "ask" }, "correct_answer": "C" },
      { "number": 26, "question_text": "If I ______ ill yesterday, I wouldn't have stayed at home.", "options": { "A": "weren't", "B": "had been", "C": "hadn't been", "D": "wasn't" }, "correct_answer": "C" },
      { "number": 27, "question_text": "He is fat because he doesn't take any exercise. If he ______ some exercise, he ______ so fat.", "options": { "A": "took / won't be", "B": "will take / won't be", "C": "takes / wouldn't be", "D": "took / wouldn't be" }, "correct_answer": "D" },
      { "number": 28, "question_text": "I'd like to go to the concert, but I haven't got a ticket. If I ______ a ticket, I ______ go to it.", "options": { "A": "had / will", "B": "have / will", "C": "will have / can", "D": "had / could" }, "correct_answer": "D" },
      { "number": 29, "question_text": "Would he have passed if he ______ hard?", "options": { "A": "studied", "B": "had studied", "C": "studies", "D": "would study" }, "correct_answer": "B" },
      { "number": 30, "question_text": "If you ______ practice, you can't learn English.", "options": { "A": "aren't", "B": "didn't", "C": "won't", "D": "don't" }, "correct_answer": "D" },
      { "number": 31, "question_text": "If I could go anywhere in the world, I ______ to Japan.", "options": { "A": "would go", "B": "will go", "C": "went", "D": "had gone" }, "correct_answer": "A" },
      { "number": 32, "question_text": "You will kill yourself if you ______ stop smoking.", "options": { "A": "aren't", "B": "didn't", "C": "don't", "D": "weren't" }, "correct_answer": "C" },
      { "number": 33, "question_text": "If the teacher ______ a little more slowly, I could understand him.", "options": { "A": "speak", "B": "will speak", "C": "speaks", "D": "spoke" }, "correct_answer": "D" },
      { "number": 34, "question_text": "If people ______ ill, they go to see a doctor.", "options": { "A": "is", "B": "are", "C": "were", "D": "will be" }, "correct_answer": "B" },
      { "number": 35, "question_text": "If she ______ him, she would marry him.", "options": { "A": "loved", "B": "would love", "C": "loves", "D": "had loved" }, "correct_answer": "A" },
      { "number": 36, "question_text": "Perhaps he would excuse you if you ______ to him yourself.", "options": { "A": "spoke", "B": "will speak", "C": "speak", "D": "had spoken" }, "correct_answer": "A" },
      { "number": 37, "question_text": "I could tell you the time if I ______ a watch.", "options": { "A": "had had", "B": "had", "C": "would have", "D": "will have" }, "correct_answer": "B" },
      { "number": 38, "question_text": "If you don't take your medicine, you ______ get well quickly.", "options": { "A": "won't", "B": "wouldn't", "C": "couldn't", "D": "aren't" }, "correct_answer": "A" },
      { "number": 39, "question_text": "I'd have been there on time if I ______.", "options": { "A": "get up early", "B": "could get on the first train", "C": "had caught the earlier bus", "D": "set my alarm clock" }, "correct_answer": "C" },
      { "number": 40, "question_text": "If the sun ______ the world ______ dark.", "options": { "A": "won't rise / will be", "B": "hadn't risen / would have been", "C": "doesn't / will be", "D": "didn't rise / would be" }, "correct_answer": "D" },
      { "number": 41, "question_text": "If Neil Armstrong had lived in 1453, he ______ on the moon.", "options": { "A": "couldn't walk", "B": "wouldn't walk", "C": "can't walk", "D": "couldn't have walked" }, "correct_answer": "D" },
      { "number": 42, "question_text": "If she ______ younger, she could start jogging.", "options": { "A": "were", "B": "would be", "C": "is", "D": "will be" }, "correct_answer": "A" },
      { "number": 43, "question_text": "He ______ angry if you argue with him.", "options": { "A": "got", "B": "get", "C": "gets", "D": "would get" }, "correct_answer": "C" },
      { "number": 44, "question_text": "Diana would have got up earlier if ______.", "options": { "A": "she knew the train left at 6.30", "B": "the alarm clock went off on time", "C": "you could have woken her up", "D": "she could sleep well" }, "correct_answer": "C" },
      { "number": 45, "question_text": "If I had listened to the weather forecast ______.", "options": { "A": "I would stay at home", "B": "I'd know it was windy", "C": "I wouldn't have watered the flowers", "D": "we were going to play football" }, "correct_answer": "C" },
      { "number": 46, "question_text": "______ they'd take you to hospital.", "options": { "A": "If you are seriously ill", "B": "If you have a terrible headache", "C": "If you got any worse", "D": "If you'd become worried" }, "correct_answer": "C" },
      { "number": 47, "question_text": "Everything would be all right if ______.", "options": { "A": "I could start on the 9th of September", "B": "you'd apologize to her", "C": "it hadn't rained", "D": "she hadn't phoned the police" }, "correct_answer": "A" },
      { "number": 48, "question_text": "______, I wouldn't have told you.", "options": { "A": "If it was a piece of bad news", "B": "If I failed the driving test", "C": "If you were dismissed", "D": "If I'd known you were going to be upset" }, "correct_answer": "D" },
      { "number": 49, "question_text": "She'd go on a diet if ______.", "options": { "A": "you ask her to do", "B": "she had had some complaints", "C": "she will marry a rich man", "D": "she appeared on TV" }, "correct_answer": "D" },
      { "number": 50, "question_text": "She wouldn't have married him if ______.", "options": { "A": "she weren't beautiful", "B": "he didn't have a lot of money", "C": "she had a villa", "D": "he hadn't been an engineer" }, "correct_answer": "D" },
      { "number": 51, "question_text": "Tell me ______.", "options": { "A": "where is the station", "B": "what is your name", "C": "why she is crying", "D": "how did you learn English" }, "correct_answer": "C" },
      { "number": 52, "question_text": "Ask the driver ______.", "options": { "A": "how long does it take to the airport", "B": "how much we'll pay", "C": "if he had any change", "D": "the car is his own" }, "correct_answer": "B" },
      { "number": 53, "question_text": "Does anybody know why ______?", "options": { "A": "does the teacher get angry", "B": "Ray is absent", "C": "is he waiting outside", "D": "are they late" }, "correct_answer": "B" },
      { "number": 54, "question_text": "\"Are you ready?\" she asked. She asked ______ ready.", "options": { "A": "if I was", "B": "when I am", "C": "to be", "D": "why I was" }, "correct_answer": "A" },
      { "number": 55, "question_text": "I don't know______.", "options": { "A": "when is it", "B": "what time it is", "C": "what time is it", "D": "when was it" }, "correct_answer": "B" },
      { "number": 56, "question_text": "I wonder why ______.", "options": { "A": "is the sky blue", "B": "was the sky blue", "C": "the sky was blue", "D": "the sky is blue" }, "correct_answer": "D" },
      { "number": 57, "question_text": "\"Why is he smiling?\" I want to know______.", "options": { "A": "why he was smiling", "B": "why was he smiling", "C": "why is he smiling", "D": "why he is smiling" }, "correct_answer": "D" },
      { "number": 58, "question_text": "I wonder whether ______ on other planets.", "options": { "A": "is there life", "B": "there was", "C": "there's life", "D": "was there" }, "correct_answer": "C" },
      { "number": 59, "question_text": "Could you tell me where ______?", "options": { "A": "the bus station was", "B": "is the bus station", "C": "the bus station is", "D": "was the bus station" }, "correct_answer": "C" },
      { "number": 60, "question_text": "She said, \"My brother is a student.\" She said that ______ a student.", "options": { "A": "my brother is", "B": "her brother was", "C": "my brother was", "D": "your brother was" }, "correct_answer": "B" },
      { "number": 61, "question_text": "\"When will you be here?\" she asked. She asked me when ______ there.", "options": { "A": "I would be", "B": "would I be", "C": "she will be", "D": "she would be" }, "correct_answer": "A" },
      { "number": 62, "question_text": "He said, \"I will watch TV\". He said ______.", "options": { "A": "I would watch TV", "B": "I will watch TV", "C": "she would watch TV", "D": "he would watch TV" }, "correct_answer": "D" },
      { "number": 63, "question_text": "\"Do you need a pen?\" Anne asked me ______ a pen.", "options": { "A": "do you need", "B": "did I need", "C": "if I needed", "D": "whether she needed" }, "correct_answer": "C" },
      { "number": 64, "question_text": "\"I may be late.\" Mike told me______ late.", "options": { "A": "he might be", "B": "I might be", "C": "he may be", "D": "he was" }, "correct_answer": "A" },
      { "number": 65, "question_text": "\"What are you talking about?\" Dick asked me what______.", "options": { "A": "am I talking about", "B": "I was talking about", "C": "he is talking about", "D": "was he talking about" }, "correct_answer": "B" },
      { "number": 66, "question_text": "\"Can you come to the party?\" David asked me ______ to the party.", "options": { "A": "could he come", "B": "can he come", "C": "if I could come", "D": "whether I can come" }, "correct_answer": "C" },
      { "number": 67, "question_text": "\"I have to study.\" Barbara said______.", "options": { "A": "she had to study", "B": "if he had to study", "C": "she has to study", "D": "if she has to study" }, "correct_answer": "A" },
      { "number": 68, "question_text": "I don't know if I ______ succeed in passing my exam or not.", "options": { "A": "will", "B": "could", "C": "would", "D": "will be" }, "correct_answer": "A" },
      { "number": 69, "question_text": "\"Have you seen my grammar book?\" Nancy wanted to know ______ grammar book.", "options": { "A": "whether she'd seen my", "B": "if I'd seen her", "C": "did I see her", "D": "I'd seen her" }, "correct_answer": "B" },
      { "number": 70, "question_text": "He explained why ______.", "options": { "A": "did he come late", "B": "was he late", "C": "late he was", "D": "he was late" }, "correct_answer": "D" },
      { "number": 71, "question_text": "My friend said, \"I can't believe it.\" He said ______ it.", "options": { "A": "he can't believe", "B": "I couldn't believe", "C": "he couldn't believe", "D": "he didn't believe" }, "correct_answer": "C" },
      { "number": 72, "question_text": "The nurse doesn't understand why the girl______.", "options": { "A": "is coughing", "B": "was coughing", "C": "would cough", "D": "cough" }, "correct_answer": "A" },
      { "number": 73, "question_text": "I didn't know if he ______ there.", "options": { "A": "were", "B": "is going to be", "C": "would be", "D": "will be" }, "correct_answer": "C" },
      { "number": 74, "question_text": "Peter asked his brother ______.", "options": { "A": "where are the hammers", "B": "where was the hammer", "C": "where is the hammer", "D": "where the hammer was" }, "correct_answer": "D" },
      { "number": 75, "question_text": "Father said that ______.", "options": { "A": "I'm at my office", "B": "he was at his office", "C": "you are at your office", "D": "\"I'm at my office\"" }, "correct_answer": "B" },
      { "number": 76, "question_text": "I heard that you ______ at the basketball match.", "options": { "A": "are", "B": "were", "C": "been", "D": "gone" }, "correct_answer": "B" },
      { "number": 77, "question_text": "George said that ______ to Tom.", "options": { "A": "he'd spoken", "B": "he's spoken", "C": "you speak", "D": "I have spoken" }, "correct_answer": "A" },
      { "number": 78, "question_text": "They promised that they ______ Mike next year.", "options": { "A": "visit", "B": "would visit", "C": "will visit", "D": "won't visit" }, "correct_answer": "B" },
      { "number": 79, "question_text": "She was sorry that ______.", "options": { "A": "she was late", "B": "she is late", "C": "was she late", "D": "to be late" }, "correct_answer": "A" },
      { "number": 80, "question_text": "\"May I use your telephone?\" He asked me if ______.", "options": { "A": "I might use his telephone", "B": "he may use his telephone", "C": "he might use my telephone", "D": "he might use his telephone" }, "correct_answer": "C" },
      { "number": 81, "question_text": "\"Can you help me?\" She wondered if ______.", "options": { "A": "I can help her", "B": "she could help me", "C": "I could help her", "D": "she can help me" }, "correct_answer": "C" },
      { "number": 82, "question_text": "I don't know where ______.", "options": { "A": "the lavatory is", "B": "is the lavatory", "C": "was the lavatory", "D": "the lavatory was" }, "correct_answer": "A" },
      { "number": 83, "question_text": "She asked me if ______ to the meeting.", "options": { "A": "I was going", "B": "I am going", "C": "she is going", "D": "would she go" }, "correct_answer": "A" },
      { "number": 84, "question_text": "The surgeon says, \"You may have some pain for a few days.\" He says that ______ some pain for a few days.", "options": { "A": "I might have", "B": "he may have", "C": "he might", "D": "I may have" }, "correct_answer": "D" },
      { "number": 85, "question_text": "She asked me, \"Can you help us?\" She wanted to know if ______.", "options": { "A": "could we help her", "B": "I could help them", "C": "we could help her", "D": "I can help them" }, "correct_answer": "B" },
      { "number": 86, "question_text": "\"Don't walk on the bridge.\" He warned us ______ on that bridge.", "options": { "A": "didn't walk", "B": "to walk", "C": "don't walk", "D": "not to walk" }, "correct_answer": "D" },
      { "number": 87, "question_text": "\"Please be quiet.\" I asked them ______ quiet.", "options": { "A": "be", "B": "not to be", "C": "to be", "D": "are" }, "correct_answer": "C" },
      { "number": 88, "question_text": "\"Shall I call a taxi?\" He asked me if ______ a taxi.", "options": { "A": "he should call", "B": "I should call", "C": "should he call", "D": "he will call" }, "correct_answer": "A" },
      { "number": 89, "question_text": "The teacher told me ______ the board.", "options": { "A": "he is cleaning", "B": "I clean", "C": "cleaning", "D": "to clean" }, "correct_answer": "D" },
      { "number": 90, "question_text": "\"Open your mouth.\" The dentist told me ______.", "options": { "A": "to open his mouth", "B": "opened my mouth", "C": "open your mouth", "D": "to open my mouth" }, "correct_answer": "D" },
      { "number": 91, "question_text": "\"Don't be late.\" The teacher told us ______.", "options": { "A": "not to be late", "B": "not being late", "C": "to be late", "D": "we don't be late" }, "correct_answer": "A" },
      { "number": 92, "question_text": "\"Are you free now?\" He asked her if ______ then.", "options": { "A": "I was free", "B": "is she free", "C": "she was free", "D": "was she free" }, "correct_answer": "C" },
      { "number": 93, "question_text": "The teacher said, \"Pick up your book, Mike.\" The teacher told Mike ______.", "options": { "A": "pick up his book", "B": "to pick up her book", "C": "to pick up my book", "D": "to pick up his book" }, "correct_answer": "D" },
