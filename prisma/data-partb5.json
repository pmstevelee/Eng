      { "number": 5, "question_text": "If I ______ time, I could go with you.", "options": { "A": "have", "B": "will have", "C": "am having", "D": "had" }, "correct_answer": "D" },
      { "number": 6, "question_text": "I'll go to the park if it ______ cold.", "options": { "A": "weren't", "B": "wasn't", "C": "isn't", "D": "doesn't" }, "correct_answer": "C" },
      { "number": 7, "question_text": "If I ______ a bird, I could fly home.", "options": { "A": "were", "B": "will be", "C": "would be", "D": "be" }, "correct_answer": "A" },
      { "number": 8, "question_text": "If the weather were nice, I ______ to the beach.", "options": { "A": "will go", "B": "would go", "C": "went", "D": "go" }, "correct_answer": "B" },
      { "number": 9, "question_text": "If she ______, she usually does well on the tests.", "options": { "A": "studied", "B": "had studied", "C": "studies", "D": "will study" }, "correct_answer": "C" },
      { "number": 10, "question_text": "If you needed the money, I ______ it to you.", "options": { "A": "would lend", "B": "lent", "C": "will lend", "D": "lend" }, "correct_answer": "A" },
      { "number": 11, "question_text": "I ______ to you if you don't come.", "options": { "A": "wouldn't talk", "B": "won't talk", "C": "didn't talk", "D": "doesn't talk" }, "correct_answer": "B" },
      { "number": 12, "question_text": "If I ______ a lot of money, I'd take a long holiday.", "options": { "A": "won", "B": "win", "C": "would win", "D": "had won" }, "correct_answer": "A" },
      { "number": 13, "question_text": "You wouldn't ______ your car if you had driven more carefully.", "options": { "A": "damage", "B": "damaged", "C": "has damaged", "D": "have damaged" }, "correct_answer": "D" },
      { "number": 14, "question_text": "If I had time, ______ see the new film at the cinema.", "options": { "A": "I'll", "B": "I'd", "C": "I can", "D": "I am" }, "correct_answer": "B" },
      { "number": 15, "question_text": "A: I smoke too much.\nB: If I ______ you, I ______ smoke at all.", "options": { "A": "was / won't", "B": "were / weren't", "C": "am / won't", "D": "were / wouldn't" }, "correct_answer": "D" },
