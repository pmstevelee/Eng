      { "number": 95, "question_text": "A: What started the fire?\nB: Nobody knows ______.", "options": { "A": "who started the fire", "B": "what started the fire", "C": "what starts the fire", "D": "who'd started the fire" }, "correct_answer": "B" },
      { "number": 96, "question_text": "A: What did Julia buy?\nB: I don't know ______.", "options": { "A": "what she bought", "B": "what she's bought", "C": "what did she buy", "D": "what she had bought" }, "correct_answer": "A" },
      { "number": 97, "question_text": "Don't look at your friend's paper. The teacher warned me ______ my friend's paper.", "options": { "A": "to look at", "B": "I don't look at", "C": "you don't look at", "D": "not to look at" }, "correct_answer": "D" },
      { "number": 98, "question_text": "He said that ______.", "options": { "A": "it is raining", "B": "she is unable to come", "C": "it was somebody else's bike", "D": "I didn't come" }, "correct_answer": "C" },
