generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum PlanType {
  BASIC
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
  CANCELED
}

enum SubscriptionPeriod {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  REFUNDED
  CANCELLED
  FAILED
  CANCELED
  PARTIAL_CANCELED
}

enum Plan {
  FREE
  STARTER
  STANDARD
  PREMIUM
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PaymentType {
  SUBSCRIPTION
  OVERAGE_AI_WRITING
  OVERAGE_AI_QUESTION
  CREDIT_PACKAGE
  ANNUAL
  STUDENT_OVERAGE
  STORAGE_OVERAGE
}

enum CreditType {
  WRITING
  QUESTION
}

enum ScheduleStatus {
  PENDING
  EXECUTED
  FAILED
  CANCELED
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
  SKIPPED
}

enum AuditActorType {
  USER
  SYSTEM
  ADMIN
  WEBHOOK
}

enum OverageMode {
  REALTIME    // 매번 사용 시 즉시 결제
  WEEKLY      // 매주 일요일 일괄 결제 (기본값)
  MONTHLY     // 매월 말일 일괄 결제
  BLOCK       // 한도 도달 시 사용 차단
}

enum Role {
  SUPER_ADMIN
  ACADEMY_OWNER
  TEACHER
  STUDENT
}

enum StudentStatus {
  ACTIVE
  ON_LEAVE
  WITHDRAWN
}

enum TestType {
  LEVEL_TEST
  UNIT_TEST
  PRACTICE
}

enum SessionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  GRADED
}

enum QuestionDomain {
  GRAMMAR
  VOCABULARY
  READING
  WRITING
  LISTENING
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum BadgeType {
  STREAK_3
  STREAK_7
  STREAK_14
  STREAK_30
  STREAK_100
  FIRST_TEST
  PERFECT_SCORE
  SPEED_DEMON
  LEVEL_UP
  MASTER
  WEEKLY_GOAL
  MISSION_COMPLETE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AnnouncementTarget {
  ALL_STUDENTS
  CLASS
}

enum TestStatus {
  DRAFT
  PUBLISHED
  GRADED
}

enum QuestionSource {
  SYSTEM           // 시스템 초기 생성
  AI_GENERATED     // AI가 생성 (유사문제 등)
  TEACHER_CREATED  // 교사가 직접 생성
  AI_SHARED        // AI 유사문제 중 공용 풀에 공유된 것
}

enum QuestionReportType {
  WRONG_ANSWER  // 정답 오류
  TYPO          // 오탈자
  UNCLEAR       // 문제 불명확
  AUDIO_ERROR   // 음원 오류
  OTHER         // 기타
}

enum QuestionReportStatus {
  PENDING    // 처리 대기
  RESOLVED   // 처리 완료
  DISMISSED  // 반려
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// 1. 학원
model Academy {
  id           String    @id @default(uuid())
  name         String
  address      String?
  phone        String?
  logoUrl      String?   @map("logo_url")
  planType     PlanType  @default(BASIC) @map("plan_type")
  settingsJson Json?     @map("settings_json")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // 구독/SaaS 필드
  businessName          String?            @map("business_name")
  ownerId               String?            @map("owner_id")
  inviteCode            String             @unique @default(uuid()) @map("invite_code")
  subscriptionStatus    SubscriptionStatus @default(TRIAL) @map("subscription_status")
  subscriptionPlan      PlanType           @default(BASIC) @map("subscription_plan")
  subscriptionStartedAt DateTime?          @map("subscription_started_at")
  subscriptionExpiresAt DateTime?          @map("subscription_expires_at")
  trialEndsAt           DateTime           @default(now()) @map("trial_ends_at")
  maxStudents           Int                @default(10) @map("max_students")
  maxTeachers           Int                @default(2) @map("max_teachers")
  isDeleted             Boolean            @default(false) @map("is_deleted")
  deletedAt             DateTime?          @map("deleted_at")

  // 다지점 관련 필드
  parentAcademyId  String?   @map("parent_academy_id")
  branchName       String?   @map("branch_name")
  branchOrder      Int       @default(0) @map("branch_order")

  owner         User?          @relation("AcademyOwner", fields: [ownerId], references: [id])
  users         User[]         @relation("AcademyUsers")
  classes       Class[]
  tests         Test[]
  questions     Question[]
  notifications Notification[]
  badges        Badge[]
  enrollments   Enrollment[]
  subscription          Subscription?
  subscriptionHistory   SubscriptionHistory[]
  announcements Announcement[]
  questionUsageLogs QuestionUsageLog[]

  // 다지점 자기참조 관계
  parentAcademy  Academy?  @relation("AcademyBranches", fields: [parentAcademyId], references: [id])
  branches       Academy[] @relation("AcademyBranches")
  wordSets       WordSet[]

  @@index([parentAcademyId])
  @@map("academies")
}

/// 2. 사용자 (Supabase Auth 연동 - id = auth.users.id)
model User {
  id        String   @id // Supabase Auth UUID
  academyId String?  @map("academy_id")
  role      Role
  name      String
  email     String   @unique
  phone     String?
  avatarUrl String?  @map("avatar_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 가입/동의 필드
  agreedTerms     Boolean   @default(false) @map("agreed_terms")
  agreedPrivacy   Boolean   @default(false) @map("agreed_privacy")
  agreedMarketing Boolean   @default(false) @map("agreed_marketing")
  lastLoginAt     DateTime? @map("last_login_at")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at")

  academy        Academy? @relation("AcademyUsers", fields: [academyId], references: [id])
  ownedAcademies Academy[] @relation("AcademyOwner")

  student          Student?
  taughtClasses    Class[]          @relation("TeacherClasses")
  createdTests     Test[]           @relation("TestCreator")
  createdQuestions  Question[]
  writtenComments   TeacherComment[] @relation("CommentAuthor")
  generatedReports  Report[]         @relation("ReportGenerator")
  notifications     Notification[]
  announcements     Announcement[]   @relation("AnnouncementAuthor")
  levelAssessments  LevelAssessment[] @relation("AssessmentOverrider")
  questionReports   QuestionReport[] @relation("ReportedBy")
  resolvedReports   QuestionReport[] @relation("ResolvedBy")
  ownedWordSets     WordSet[]         @relation("OwnedWordSets")

  @@index([academyId])
  @@map("users")
}

/// 3. 학생 상세
model Student {
  id           String        @id @default(uuid())
  userId       String        @unique @map("user_id")
  grade               String?
  currentLevel        Int           @default(1) @map("current_level") // 1~10
  classId             String?       @map("class_id")
  status              StudentStatus @default(ACTIVE)
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  totalXp             Int           @default(0) @map("total_xp")
  weeklyGoalTarget    Int           @default(20) @map("weekly_goal_target")
  weeklyGoalCurrent   Int           @default(0) @map("weekly_goal_current")
  weeklyGoalResetAt   DateTime      @default(now()) @map("weekly_goal_reset_at")

  user  User   @relation(fields: [userId], references: [id])
  class Class? @relation(fields: [classId], references: [id])

  testSessions     TestSession[]
  skillAssessments SkillAssessment[]
  learningPaths    LearningPath[]
  teacherComments  TeacherComment[]
  reports          Report[]
  attendance       Attendance[]
  badgeEarnings    BadgeEarning[]
  enrollments      Enrollment[]
  streak           StudentStreak?
  dailyMissions    DailyMission[]
  practiceLogs     PracticeLog[]
  xpHistory        StudentXp[]
  levelAssessments LevelAssessment[]
  promotionStatus  LevelPromotionStatus?
  wordProgress     WordProgress[]
  wordTests        WordTest[]

  @@index([classId])
  @@index([status])
  @@map("students")
}

/// 4. 반
model Class {
  id           String   @id @default(uuid())
  academyId    String   @map("academy_id")
  name         String
  levelRange   String?  @map("level_range")
  teacherId    String?  @map("teacher_id")
  scheduleJson Json?    @map("schedule_json")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  academy  Academy @relation(fields: [academyId], references: [id])
  teacher  User?   @relation("TeacherClasses", fields: [teacherId], references: [id])

  students      Student[]
  attendance    Attendance[]
  enrollments   Enrollment[]
  tests         Test[]
  announcements Announcement[]

  @@index([academyId])
  @@index([teacherId])
  @@map("classes")
}

/// 5. 테스트 정의
model Test {
  id            String     @id @default(uuid())
  academyId     String     @map("academy_id")
  title         String
  type          TestType
  status        TestStatus @default(DRAFT)
  levelRange    String?    @map("level_range")
  classId       String?    @map("class_id")
  totalScore    Int        @default(100) @map("total_score")
  timeLimitMin  Int?       @map("time_limit_min")
  instructions  String?
  questionOrder Json?      @map("question_order")
  createdBy     String     @map("created_by")
  isActive      Boolean    @default(true) @map("is_active")
  createdAt     DateTime   @default(now()) @map("created_at")

  // 적응형 레벨 테스트 필드
  isAdaptive     Boolean @default(false) @map("is_adaptive")
  adaptiveConfig Json?   @map("adaptive_config")

  // 단원 테스트 필드 (승급 조건 연동)
  targetLevel        Int?    @map("target_level")         // 이 테스트의 대상 레벨 (1~10)
  unitName           String? @map("unit_name")            // 단원명 (예: "Unit 3: 관계대명사")
  learningObjectives String? @map("learning_objectives")  // 학습 목표

  academy      Academy       @relation(fields: [academyId], references: [id])
  creator      User          @relation("TestCreator", fields: [createdBy], references: [id])
  class        Class?        @relation(fields: [classId], references: [id])
  testSessions TestSession[]

  @@index([academyId])
  @@index([classId])
  @@index([status])
  @@map("tests")
}

/// 6. 테스트 응시 세션
model TestSession {
  id                 String        @id @default(uuid())
  testId             String        @map("test_id")
  studentId          String        @map("student_id")
  score              Int?
  grammarScore       Int?          @map("grammar_score")
  vocabularyScore    Int?          @map("vocabulary_score")
  readingScore       Int?          @map("reading_score")
  writingScore       Int?          @map("writing_score")
  listeningScore     Int?          @map("listening_score")
  startedAt          DateTime      @default(now()) @map("started_at")
  completedAt        DateTime?     @map("completed_at")
  timeLimitMin       Int?          @map("time_limit_min")
  currentQuestionIdx Int           @default(0) @map("current_question_idx")
  lastSavedAt        DateTime?     @map("last_saved_at")
  status             SessionStatus @default(NOT_STARTED)

  // 적응형 레벨 테스트 결과 필드
  isPlacement     Boolean @default(false) @map("is_placement")
  assessedLevels  Json?   @map("assessed_levels")
  placementResult Json?   @map("placement_result")

  test              Test               @relation(fields: [testId], references: [id])
  student           Student            @relation(fields: [studentId], references: [id])
  questionResponses QuestionResponse[]
  levelAssessments  LevelAssessment[]

  @@index([testId])
  @@index([studentId])
  @@index([status])
  @@index([completedAt])
  @@map("test_sessions")
}

/// 7. 문제 뱅크
model Question {
  id          String         @id @default(uuid())
  academyId   String?        @map("academy_id") // null: 공용, 특정 ID: 해당 학원 전용
  domain      QuestionDomain
  subCategory String?        @map("sub_category")
  difficulty  Int            @default(1) // 1~10
  cefrLevel   String?        @map("cefr_level") // Pre-A1, A1 하, A1 상, A2 하, A2 상, B1 하, B1 상, B2 하, B2 상, C1+
  contentJson Json           @map("content_json")
  statsJson   Json?          @map("stats_json")
  createdBy   String?        @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")

  // 공용 문제 뱅크 필드
  source             QuestionSource @default(SYSTEM)
  isVerified         Boolean        @default(false) @map("is_verified")
  usageCount         Int            @default(0) @map("usage_count")
  qualityScore       Float?         @map("quality_score")
  isActive           Boolean        @default(true) @map("is_active")
  originalQuestionId String?        @map("original_question_id") // AI 유사문제인 경우 원본 ID

  academy          Academy?           @relation(fields: [academyId], references: [id])
  creator          User?              @relation(fields: [createdBy], references: [id])
  responses        QuestionResponse[]
  usageLogs        QuestionUsageLog[]
  reports          QuestionReport[]
  originalQuestion Question?          @relation("QuestionVariants", fields: [originalQuestionId], references: [id])
  variants         Question[]         @relation("QuestionVariants")

  @@index([academyId])
  @@index([academyId, domain, difficulty, isActive])
  @@index([source, isVerified, isActive])
  @@index([domain, difficulty, isActive, isVerified])
  @@index([qualityScore])
  @@map("questions")
}

/// 8. 문제 응답
model QuestionResponse {
  id                 String    @id @default(uuid())
  sessionId          String    @map("session_id")
  questionId         String    @map("question_id")
  answer             String?
  answerJson         Json?     @map("answer_json")
  isCorrect          Boolean?  @map("is_correct")
  timeSpentSec       Int?      @map("time_spent_sec")
  createdAt          DateTime  @default(now()) @map("created_at")

  // 스페이스드 리피티션
  reviewDueAt        DateTime? @map("review_due_at")
  reviewCount        Int       @default(0) @map("review_count")
  consecutiveCorrect Int       @default(0) @map("consecutive_correct")
  isMastered         Boolean   @default(false) @map("is_mastered")

  session  TestSession @relation(fields: [sessionId], references: [id])
  question Question    @relation(fields: [questionId], references: [id])

  @@index([sessionId])
  @@index([questionId])
  @@index([reviewDueAt])
  @@map("question_responses")
}

/// 9. 영역별 스킬 평가
model SkillAssessment {
  id         String         @id @default(uuid())
  studentId  String         @map("student_id")
  domain     QuestionDomain
  level      Int
  score      Int?
  notes      String?
  assessedAt DateTime       @default(now()) @map("assessed_at")

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("skill_assessments")
}

/// 10. 학습 경로
model LearningPath {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  title        String
  description  String?
  goalsJson    Json?    @map("goals_json")
  progressJson Json?    @map("progress_json")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("learning_paths")
}

/// 11. 교사 코멘트
model TeacherComment {
  id        String   @id @default(uuid())
  teacherId String   @map("teacher_id")
  studentId String   @map("student_id")
  content   String
  type      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teacher User    @relation("CommentAuthor", fields: [teacherId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([teacherId])
  @@map("teacher_comments")
}

/// 12. 리포트
model Report {
  id          String    @id @default(uuid())
  studentId   String    @map("student_id")
  generatedBy String?   @map("generated_by")
  type        String
  periodStart DateTime? @map("period_start")
  periodEnd   DateTime? @map("period_end")
  dataJson    Json      @map("data_json")
  createdAt   DateTime  @default(now()) @map("created_at")

  student   Student @relation(fields: [studentId], references: [id])
  generator User?   @relation("ReportGenerator", fields: [generatedBy], references: [id])

  @@index([studentId])
  @@map("reports")
}

/// 13. 알림
model Notification {
  id             String           @id @default(uuid())
  userId         String           @map("user_id")
  academyId      String?          @map("academy_id")
  type           NotificationType @default(INFO)
  title          String
  message        String
  link           String?
  relatedId      String?          @map("related_id")
  isRead         Boolean          @default(false) @map("is_read")
  createdAt      DateTime         @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id])
  academy Academy? @relation(fields: [academyId], references: [id])

  @@index([userId])
  @@index([academyId])
  @@index([createdAt])
  @@map("notifications")
}

/// 19. 공지사항
model Announcement {
  id          String             @id @default(uuid())
  academyId   String             @map("academy_id")
  authorId    String             @map("author_id")
  classId     String?            @map("class_id")
  title       String
  content     String
  target      AnnouncementTarget @default(ALL_STUDENTS)
  isPublished Boolean            @default(true) @map("is_published")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  academy Academy @relation(fields: [academyId], references: [id])
  author  User    @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  class   Class?  @relation(fields: [classId], references: [id])

  @@index([academyId])
  @@map("announcements")
}

/// 14. 출석
model Attendance {
  id        String           @id @default(uuid())
  studentId String           @map("student_id")
  classId   String           @map("class_id")
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  note      String?
  createdAt DateTime         @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, date])
  @@index([studentId])
  @@index([classId])
  @@map("attendance")
}

/// 15. 배지
model Badge {
  id          String     @id @default(uuid())
  academyId   String?    @map("academy_id")
  code        BadgeType? @unique
  name        String
  description String?
  iconUrl     String?    @map("icon_url")
  criteria    Json?
  createdAt   DateTime   @default(now()) @map("created_at")

  academy  Academy?      @relation(fields: [academyId], references: [id])
  earnings BadgeEarning[]

  @@map("badges")
}

/// 16-a. 학습 스트릭
model StudentStreak {
  id               String    @id @default(uuid())
  studentId        String    @unique @map("student_id")
  currentStreak    Int       @default(0) @map("current_streak")
  longestStreak    Int       @default(0) @map("longest_streak")
  lastActivityDate DateTime? @map("last_activity_date")
  totalDays        Int       @default(0) @map("total_days")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])

  @@map("student_streaks")
}

/// 16-b. 오늘의 미션
model DailyMission {
  id               String    @id @default(uuid())
  studentId        String    @map("student_id")
  missionDate      DateTime  @map("mission_date")
  questionIds      Json      @map("question_ids")
  domainFocus      String?   @map("domain_focus")
  isCompleted      Boolean   @default(false) @map("is_completed")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  status           String    @default("GENERATED")
  missionsJson     Json?     @map("missions_json")
  totalMissions    Int       @default(0) @map("total_missions")
  completedMissions Int      @default(0) @map("completed_missions")
  startedAt        DateTime? @map("started_at")
  xpEarned         Int       @default(0) @map("xp_earned")
  streakCounted    Boolean   @default(false) @map("streak_counted")

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, missionDate])
  @@index([status])
  @@map("daily_missions")
}

/// 16-c. 학생 XP 기록
model StudentXp {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount    Int
  source    String
  sourceId  String?  @map("source_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([studentId])
  @@index([createdAt])
  @@map("student_xp")
}

model BadgeEarning {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  badgeId   String   @map("badge_id")
  earnedAt  DateTime @default(now()) @map("earned_at")

  student Student @relation(fields: [studentId], references: [id])
  badge   Badge   @relation(fields: [badgeId], references: [id])

  @@unique([studentId, badgeId])
  @@map("badge_earnings")
}

/// 17. 수강 등록
model Enrollment {
  id         String   @id @default(uuid())
  studentId  String   @map("student_id")
  classId    String   @map("class_id")
  academyId  String   @map("academy_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])
  academy Academy @relation(fields: [academyId], references: [id])

  @@unique([studentId, classId])
  @@index([academyId])
  @@map("enrollments")
}

/// 17. 구독 이력 (레거시 - 구결제 기록용)
model SubscriptionHistory {
  id            String             @id @default(uuid())
  academyId     String             @map("academy_id")
  plan          PlanType
  amount        Int
  period        SubscriptionPeriod
  startedAt     DateTime           @map("started_at")
  expiresAt     DateTime           @map("expires_at")
  paymentMethod String?            @map("payment_method")
  paymentRef    String?            @map("payment_ref")
  status        PaymentStatus      @default(PENDING)
  createdAt     DateTime           @default(now()) @map("created_at")

  academy Academy @relation(fields: [academyId], references: [id])

  @@index([academyId])
  @@map("subscription_histories")
}

/// 25. 구독 (포트원 기반 SaaS 구독)
model Subscription {
  id                 String             @id @default(uuid())
  academyId          String             @unique @map("academy_id")
  plan               Plan               @default(FREE)
  billingCycle       BillingCycle       @default(MONTHLY) @map("billing_cycle")
  status             SubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  overageMode        OverageMode        @default(WEEKLY) @map("overage_mode")
  overageBlocked     Boolean            @default(false) @map("overage_blocked")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  academy        Academy          @relation(fields: [academyId], references: [id])
  billingKey     BillingKey?
  payments       Payment[]
  usageRecords   UsageRecord[]
  schedules      PaymentSchedule[]

  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

/// 26. 포트원 빌링키
model BillingKey {
  id                  String   @id @default(uuid())
  subscriptionId      String   @unique @map("subscription_id")
  portoneBillingKey   String   @unique @map("portone_billing_key")
  cardCompany         String?  @map("card_company")
  cardNumberMasked    String?  @map("card_number_masked")
  issuedAt            DateTime @map("issued_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("billing_keys")
}

/// 27. 결제 내역
model Payment {
  id             String        @id @default(uuid())
  subscriptionId String        @map("subscription_id")
  academyId      String        @map("academy_id")
  paymentId      String        @unique @map("payment_id") // 포트원 paymentId
  type           PaymentType
  amount         Int
  status         PaymentStatus @default(PENDING)
  pgProvider     String?       @map("pg_provider")
  pgTxId         String?       @map("pg_tx_id")
  receiptUrl     String?       @map("receipt_url")
  failureReason  String?       @map("failure_reason")
  paidAt         DateTime?     @map("paid_at")
  canceledAt     DateTime?     @map("canceled_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([academyId])
  @@index([status])
  @@index([type])
  @@index([paidAt])
  @@map("payments")
}

/// 28. 사용량 기록
model UsageRecord {
  id               String   @id @default(uuid())
  subscriptionId   String   @map("subscription_id")
  academyId        String   @map("academy_id")
  periodStart      DateTime @map("period_start")
  periodEnd        DateTime @map("period_end")
  aiWritingCount   Int      @default(0) @map("ai_writing_count")
  aiQuestionCount  Int      @default(0) @map("ai_question_count")
  storageUsedMb    Int      @default(0) @map("storage_used_mb")
  studentCount     Int      @default(0) @map("student_count")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriptionId, periodStart])
  @@index([academyId])
  @@index([periodStart])
  @@map("usage_records")
}

/// 29. AI 크레딧
model AiCredit {
  id         String     @id @default(uuid())
  academyId  String     @map("academy_id")
  type       CreditType
  amount     Int
  expiresAt  DateTime?  @map("expires_at")
  paymentId  String?    @map("payment_id")
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([academyId])
  @@index([type])
  @@index([expiresAt])
  @@map("ai_credits")
}

/// 30. 결제 예약
model PaymentSchedule {
  id             String         @id @default(uuid())
  subscriptionId String         @map("subscription_id")
  scheduledAt    DateTime       @map("scheduled_at")
  type           PaymentType
  amount         Int
  status         ScheduleStatus @default(PENDING)
  retryCount     Int            @default(0) @map("retry_count")
  metadata       Json?

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([status])
  @@index([scheduledAt])
  @@map("payment_schedules")
}

/// 20. 학습공간 연습 로그
model PracticeLog {
  id           String          @id @default(uuid())
  studentId    String          @map("student_id")
  mode         String          // "adaptive" | "domain" | "review"
  domain       QuestionDomain?
  totalCount   Int             @map("total_count")
  correctCount Int             @map("correct_count")
  score        Int
  resultsJson  Json            @map("results_json")
  createdAt    DateTime        @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([createdAt])
  @@map("practice_logs")
}

/// 21. 문제 사용 이력 (같은 학원에 재출제 방지)
model QuestionUsageLog {
  id         String   @id @default(uuid())
  questionId String   @map("question_id")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  academyId  String   @map("academy_id")
  academy    Academy  @relation(fields: [academyId], references: [id], onDelete: Cascade)
  testType   String   @map("test_type") // LEVEL_TEST, UNIT_TEST, PRACTICE
  testId     String   @map("test_id")
  usedAt     DateTime @default(now()) @map("used_at")

  @@unique([questionId, academyId, testType])
  @@index([academyId, testType])
  @@index([questionId])
  @@map("question_usage_log")
}

/// 22. 문제 뱅크 통계 캐시
model QuestionBankStats {
  id              String   @id @default(uuid())
  domain          String   // GRAMMAR, VOCABULARY, READING, WRITING
  difficulty      Int      // 1~10
  totalCount      Int      @default(0) @map("total_count")
  verifiedCount   Int      @default(0) @map("verified_count")
  avgQualityScore Float?   @map("avg_quality_score")
  lastUpdatedAt   DateTime @default(now()) @map("last_updated_at")

  @@unique([domain, difficulty])
  @@map("question_bank_stats")
}

/// 23. 레벨 평가 이력 (적응형 배치고사 결과)
model LevelAssessment {
  id             String    @id @default(uuid())
  studentId      String    @map("student_id")
  testSessionId  String?   @map("test_session_id")
  overrideBy     String?   @map("override_by") // 교사 수동 조정 시 user id
  assessmentType String    @map("assessment_type") // PLACEMENT, PERIODIC, PROMOTION, TEACHER_OVERRIDE
  grammarLevel   Int       @map("grammar_level")
  vocabularyLevel Int      @map("vocabulary_level")
  readingLevel   Int       @map("reading_level")
  listeningLevel Int?      @map("listening_level")   // null: 듣기 문제 부족으로 미측정
  writingLevel   Int       @map("writing_level")
  overallLevel   Int       @map("overall_level")
  detailJson     Json      @map("detail_json")
  assessedAt     DateTime  @default(now()) @map("assessed_at")
  assessedBy     String    @map("assessed_by") // SYSTEM, TEACHER_OVERRIDE
  isCurrent      Boolean   @default(true) @map("is_current")

  student     Student      @relation(fields: [studentId], references: [id])
  testSession TestSession? @relation(fields: [testSessionId], references: [id])
  overrider   User?        @relation("AssessmentOverrider", fields: [overrideBy], references: [id])

  @@index([studentId])
  @@index([isCurrent])
  @@index([studentId, isCurrent])
  @@map("level_assessments")
}

/// 24. 레벨 승급 상태 추적
model LevelPromotionStatus {
  id               String    @id @default(uuid())
  studentId        String    @unique @map("student_id")
  currentLevel     Int       @map("current_level")
  targetLevel      Int       @map("target_level")
  condition1Met    Boolean   @default(false) @map("condition1_met")    // 레벨 테스트: 4영역 중 3개 이상 목표 레벨 충족
  condition1Detail Json?     @map("condition1_detail")                  // 영역별 측정 레벨
  condition2Met    Boolean   @default(false) @map("condition2_met")    // 단원 테스트: 이수율 70%↑ + 평균 60점↑
  condition2Detail Json?     @map("condition2_detail")                  // 이수율, 평균점수
  condition3Met    Boolean   @default(false) @map("condition3_met")    // 학습 활동: 문제 50개↑ 또는 미션 20일↑
  condition3Detail Json?     @map("condition3_detail")                  // 문제 수, 미션 완료일
  allConditionsMet Boolean   @default(false) @map("all_conditions_met")
  promotedAt       DateTime? @map("promoted_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("level_promotion_status")
}

/// 31. 포트원 웹훅 이벤트 (멱등성 보장)
model WebhookEvent {
  id          String        @id @default(uuid())
  eventId     String        @unique @map("event_id")  // 포트원 webhook id
  eventType   String        @map("event_type")
  payload     Json
  status      WebhookStatus @default(RECEIVED)
  errorMsg    String?       @map("error_msg")
  receivedAt  DateTime      @default(now()) @map("received_at")
  processedAt DateTime?     @map("processed_at")

  @@index([eventType])
  @@index([status])
  @@index([receivedAt])
  @@map("webhook_events")
}

/// 32. 결제 감사 로그
model PaymentAuditLog {
  id         String         @id @default(uuid())
  actorType  AuditActorType @map("actor_type")
  actorId    String?        @map("actor_id")     // userId or "SYSTEM"
  action     String                               // e.g. PAYMENT_VERIFIED, SUBSCRIPTION_ACTIVATED
  target     String                               // e.g. "Payment:pay_xxx"
  metadata   Json?
  ip         String?
  userAgent  String?        @map("user_agent")
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([actorType, actorId])
  @@index([action])
  @@index([createdAt])
  @@map("payment_audit_logs")
}

/// 33. 문제 오류 신고
model QuestionReport {
  id          String               @id @default(uuid())
  questionId  String               @map("question_id")
  reportedBy  String               @map("reported_by") // userId
  reportType  QuestionReportType   @map("report_type")
  description String?
  status      QuestionReportStatus @default(PENDING)
  resolvedBy  String?              @map("resolved_by") // userId
  resolvedAt  DateTime?            @map("resolved_at")
  resolveNote String?              @map("resolve_note")
  createdAt   DateTime             @default(now()) @map("created_at")

  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  reporter   User     @relation("ReportedBy", fields: [reportedBy], references: [id])
  resolver   User?    @relation("ResolvedBy", fields: [resolvedBy], references: [id])

  @@index([questionId])
  @@index([reportedBy])
  @@index([status])
  @@index([createdAt])
  @@map("question_reports")
}

/// 18. 요금제 정의
model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String   @unique
  displayName  String   @map("display_name")
  monthlyPrice Int      @map("monthly_price")
  yearlyPrice  Int      @map("yearly_price")
  maxStudents  Int      @map("max_students")
  maxTeachers  Int      @map("max_teachers")
  featuresJson Json     @map("features_json")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("subscription_plans")
}

// ─── Word Learning Module ─────────────────────────────────────────────────────

enum WordSource {
  OXFORD_3000
  OXFORD_5000
  PUBLISHER
  TEACHER
  AI_GENERATED
}

enum WordSetSource {
  PUBLISHER
  TEACHER
  AI_GENERATED
  OXFORD_3000
  OXFORD_5000
}

enum LearnStage {
  FLASHCARD
  RECALL
  SPELL
  MASTERED
}

enum WordTestMode {
  EN_TO_KO
  KO_TO_EN
  SPELL
  MIXED
}

enum OxfordCefr {
  A1
  A2
  B1
  B2
  C1
}

/// 단어 마스터 (Oxford 기반)
model Word {
  id            String      @id @default(uuid())
  term          String
  partOfSpeech  String      @map("part_of_speech")
  cefrLevel     Int         @map("cefr_level") // 위고업 1~10
  oxfordCefr    OxfordCefr  @map("oxford_cefr")
  contextNote   String?     @map("context_note")
  homonymIndex  Int?        @map("homonym_index")
  meaning       String?
  definition    String?
  example       String?
  audioUrl      String?     @map("audio_url")
  source        WordSource  @default(OXFORD_3000)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  wordSetItems  WordSetItem[]
  wordProgress  WordProgress[]

  @@unique([term, partOfSpeech, homonymIndex])
  @@index([cefrLevel])
  @@index([oxfordCefr])
  @@map("words")
}

/// 단어 세트
model WordSet {
  id          String        @id @default(uuid())
  title       String
  description String?
  cefrLevel   Int           @map("cefr_level")
  isPublic    Boolean       @default(false) @map("is_public")
  source      WordSetSource
  ownerId     String?       @map("owner_id")
  academyId   String?       @map("academy_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  owner     User?     @relation("OwnedWordSets", fields: [ownerId], references: [id])
  academy   Academy?  @relation(fields: [academyId], references: [id])

  items     WordSetItem[]
  wordTests WordTest[]

  @@index([ownerId])
  @@index([academyId])
  @@map("word_sets")
}

/// 단어 세트 항목 (N:M + 순서)
model WordSetItem {
  id      String  @id @default(uuid())
  setId   String  @map("set_id")
  wordId  String  @map("word_id")
  order   Int

  wordSet WordSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  word    Word    @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([setId, wordId])
  @@index([setId])
  @@map("word_set_items")
}

/// 학생 단어 학습 진도 (스페이스드 리피티션)
model WordProgress {
  id            String      @id @default(uuid())
  studentId     String      @map("student_id")
  wordId        String      @map("word_id")
  stage         LearnStage  @default(FLASHCARD)
  easeFactor    Float       @default(2.5) @map("ease_factor")
  intervalDays  Int         @default(0) @map("interval_days")
  repetitions   Int         @default(0)
  nextReviewAt  DateTime?   @map("next_review_at")
  correctCount  Int         @default(0) @map("correct_count")
  wrongCount    Int         @default(0) @map("wrong_count")
  lastStudiedAt DateTime?   @map("last_studied_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  word    Word    @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([studentId, wordId])
  @@index([studentId, nextReviewAt])
  @@map("word_progress")
}

/// 단어 테스트 결과
model WordTest {
  id             String      @id @default(uuid())
  studentId      String      @map("student_id")
  setId          String?     @map("set_id")
  mode           WordTestMode
  score          Int
  totalQuestions Int         @map("total_questions")
  answers        Json
  takenAt        DateTime    @default(now()) @map("taken_at")

  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  wordSet WordSet? @relation(fields: [setId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([setId])
  @@map("word_tests")
}
