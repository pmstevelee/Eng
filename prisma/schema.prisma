generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum PlanType {
  BASIC
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum SubscriptionPeriod {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  REFUNDED
  CANCELLED
}

enum Role {
  SUPER_ADMIN
  ACADEMY_OWNER
  TEACHER
  STUDENT
}

enum StudentStatus {
  ACTIVE
  ON_LEAVE
  WITHDRAWN
}

enum TestType {
  LEVEL_TEST
  UNIT_TEST
  PRACTICE
}

enum SessionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  GRADED
}

enum QuestionDomain {
  GRAMMAR
  VOCABULARY
  READING
  WRITING
  LISTENING
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum BadgeType {
  STREAK_3
  STREAK_7
  STREAK_14
  STREAK_30
  STREAK_100
  FIRST_TEST
  PERFECT_SCORE
  SPEED_DEMON
  LEVEL_UP
  MASTER
  WEEKLY_GOAL
  MISSION_COMPLETE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AnnouncementTarget {
  ALL_STUDENTS
  CLASS
}

enum TestStatus {
  DRAFT
  PUBLISHED
  GRADED
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// 1. 학원
model Academy {
  id           String    @id @default(uuid())
  name         String
  address      String?
  phone        String?
  logoUrl      String?   @map("logo_url")
  planType     PlanType  @default(BASIC) @map("plan_type")
  settingsJson Json?     @map("settings_json")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // 구독/SaaS 필드
  businessName          String?            @map("business_name")
  ownerId               String?            @map("owner_id")
  inviteCode            String             @unique @default(uuid()) @map("invite_code")
  subscriptionStatus    SubscriptionStatus @default(TRIAL) @map("subscription_status")
  subscriptionPlan      PlanType           @default(BASIC) @map("subscription_plan")
  subscriptionStartedAt DateTime?          @map("subscription_started_at")
  subscriptionExpiresAt DateTime?          @map("subscription_expires_at")
  trialEndsAt           DateTime           @default(now()) @map("trial_ends_at")
  maxStudents           Int                @default(10) @map("max_students")
  maxTeachers           Int                @default(2) @map("max_teachers")
  isDeleted             Boolean            @default(false) @map("is_deleted")
  deletedAt             DateTime?          @map("deleted_at")

  owner         User?          @relation("AcademyOwner", fields: [ownerId], references: [id])
  users         User[]         @relation("AcademyUsers")
  classes       Class[]
  tests         Test[]
  questions     Question[]
  notifications Notification[]
  badges        Badge[]
  enrollments   Enrollment[]
  subscriptions Subscription[]
  announcements Announcement[]

  @@map("academies")
}

/// 2. 사용자 (Supabase Auth 연동 - id = auth.users.id)
model User {
  id        String   @id // Supabase Auth UUID
  academyId String?  @map("academy_id")
  role      Role
  name      String
  email     String   @unique
  phone     String?
  avatarUrl String?  @map("avatar_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 가입/동의 필드
  agreedTerms     Boolean   @default(false) @map("agreed_terms")
  agreedPrivacy   Boolean   @default(false) @map("agreed_privacy")
  agreedMarketing Boolean   @default(false) @map("agreed_marketing")
  lastLoginAt     DateTime? @map("last_login_at")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at")

  academy        Academy? @relation("AcademyUsers", fields: [academyId], references: [id])
  ownedAcademies Academy[] @relation("AcademyOwner")

  student          Student?
  taughtClasses    Class[]          @relation("TeacherClasses")
  createdTests     Test[]           @relation("TestCreator")
  createdQuestions Question[]
  writtenComments  TeacherComment[] @relation("CommentAuthor")
  generatedReports Report[]         @relation("ReportGenerator")
  notifications    Notification[]
  announcements    Announcement[]   @relation("AnnouncementAuthor")

  @@index([academyId])
  @@map("users")
}

/// 3. 학생 상세
model Student {
  id           String        @id @default(uuid())
  userId       String        @unique @map("user_id")
  grade               Int?
  currentLevel        Int           @default(1) @map("current_level")
  classId             String?       @map("class_id")
  status              StudentStatus @default(ACTIVE)
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  totalXp             Int           @default(0) @map("total_xp")
  weeklyGoalTarget    Int           @default(20) @map("weekly_goal_target")
  weeklyGoalCurrent   Int           @default(0) @map("weekly_goal_current")
  weeklyGoalResetAt   DateTime      @default(now()) @map("weekly_goal_reset_at")

  user  User   @relation(fields: [userId], references: [id])
  class Class? @relation(fields: [classId], references: [id])

  testSessions     TestSession[]
  skillAssessments SkillAssessment[]
  learningPaths    LearningPath[]
  teacherComments  TeacherComment[]
  reports          Report[]
  attendance       Attendance[]
  badgeEarnings    BadgeEarning[]
  enrollments      Enrollment[]
  streak           StudentStreak?
  dailyMissions    DailyMission[]
  practiceLogs     PracticeLog[]
  xpHistory        StudentXp[]

  @@index([classId])
  @@index([status])
  @@map("students")
}

/// 4. 반
model Class {
  id           String   @id @default(uuid())
  academyId    String   @map("academy_id")
  name         String
  levelRange   String?  @map("level_range")
  teacherId    String?  @map("teacher_id")
  scheduleJson Json?    @map("schedule_json")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  academy  Academy @relation(fields: [academyId], references: [id])
  teacher  User?   @relation("TeacherClasses", fields: [teacherId], references: [id])

  students      Student[]
  attendance    Attendance[]
  enrollments   Enrollment[]
  tests         Test[]
  announcements Announcement[]

  @@index([academyId])
  @@index([teacherId])
  @@map("classes")
}

/// 5. 테스트 정의
model Test {
  id            String     @id @default(uuid())
  academyId     String     @map("academy_id")
  title         String
  type          TestType
  status        TestStatus @default(DRAFT)
  levelRange    String?    @map("level_range")
  classId       String?    @map("class_id")
  totalScore    Int        @default(100) @map("total_score")
  timeLimitMin  Int?       @map("time_limit_min")
  instructions  String?
  questionOrder Json?      @map("question_order")
  createdBy     String     @map("created_by")
  isActive      Boolean    @default(true) @map("is_active")
  createdAt     DateTime   @default(now()) @map("created_at")

  academy      Academy       @relation(fields: [academyId], references: [id])
  creator      User          @relation("TestCreator", fields: [createdBy], references: [id])
  class        Class?        @relation(fields: [classId], references: [id])
  testSessions TestSession[]

  @@index([academyId])
  @@index([classId])
  @@index([status])
  @@map("tests")
}

/// 6. 테스트 응시 세션
model TestSession {
  id                 String        @id @default(uuid())
  testId             String        @map("test_id")
  studentId          String        @map("student_id")
  score              Int?
  grammarScore       Int?          @map("grammar_score")
  vocabularyScore    Int?          @map("vocabulary_score")
  readingScore       Int?          @map("reading_score")
  writingScore       Int?          @map("writing_score")
  listeningScore     Int?          @map("listening_score")
  startedAt          DateTime      @default(now()) @map("started_at")
  completedAt        DateTime?     @map("completed_at")
  timeLimitMin       Int?          @map("time_limit_min")
  currentQuestionIdx Int           @default(0) @map("current_question_idx")
  lastSavedAt        DateTime?     @map("last_saved_at")
  status             SessionStatus @default(NOT_STARTED)

  test              Test               @relation(fields: [testId], references: [id])
  student           Student            @relation(fields: [studentId], references: [id])
  questionResponses QuestionResponse[]

  @@index([testId])
  @@index([studentId])
  @@index([status])
  @@index([completedAt])
  @@map("test_sessions")
}

/// 7. 문제 뱅크
model Question {
  id          String         @id @default(uuid())
  academyId   String?        @map("academy_id")
  domain      QuestionDomain
  subCategory String?        @map("sub_category")
  difficulty  Int            @default(1)
  cefrLevel   String?        @map("cefr_level")
  contentJson Json           @map("content_json")
  statsJson   Json?          @map("stats_json")
  createdBy   String?        @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")

  academy   Academy?           @relation(fields: [academyId], references: [id])
  creator   User?              @relation(fields: [createdBy], references: [id])
  responses QuestionResponse[]

  @@index([academyId])
  @@map("questions")
}

/// 8. 문제 응답
model QuestionResponse {
  id                 String    @id @default(uuid())
  sessionId          String    @map("session_id")
  questionId         String    @map("question_id")
  answer             String?
  answerJson         Json?     @map("answer_json")
  isCorrect          Boolean?  @map("is_correct")
  timeSpentSec       Int?      @map("time_spent_sec")
  createdAt          DateTime  @default(now()) @map("created_at")

  // 스페이스드 리피티션
  reviewDueAt        DateTime? @map("review_due_at")
  reviewCount        Int       @default(0) @map("review_count")
  consecutiveCorrect Int       @default(0) @map("consecutive_correct")
  isMastered         Boolean   @default(false) @map("is_mastered")

  session  TestSession @relation(fields: [sessionId], references: [id])
  question Question    @relation(fields: [questionId], references: [id])

  @@index([sessionId])
  @@index([questionId])
  @@index([reviewDueAt])
  @@map("question_responses")
}

/// 9. 영역별 스킬 평가
model SkillAssessment {
  id         String         @id @default(uuid())
  studentId  String         @map("student_id")
  domain     QuestionDomain
  level      Int
  score      Int?
  notes      String?
  assessedAt DateTime       @default(now()) @map("assessed_at")

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("skill_assessments")
}

/// 10. 학습 경로
model LearningPath {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  title        String
  description  String?
  goalsJson    Json?    @map("goals_json")
  progressJson Json?    @map("progress_json")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("learning_paths")
}

/// 11. 교사 코멘트
model TeacherComment {
  id        String   @id @default(uuid())
  teacherId String   @map("teacher_id")
  studentId String   @map("student_id")
  content   String
  type      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teacher User    @relation("CommentAuthor", fields: [teacherId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([teacherId])
  @@map("teacher_comments")
}

/// 12. 리포트
model Report {
  id          String    @id @default(uuid())
  studentId   String    @map("student_id")
  generatedBy String?   @map("generated_by")
  type        String
  periodStart DateTime? @map("period_start")
  periodEnd   DateTime? @map("period_end")
  dataJson    Json      @map("data_json")
  createdAt   DateTime  @default(now()) @map("created_at")

  student   Student @relation(fields: [studentId], references: [id])
  generator User?   @relation("ReportGenerator", fields: [generatedBy], references: [id])

  @@index([studentId])
  @@map("reports")
}

/// 13. 알림
model Notification {
  id             String           @id @default(uuid())
  userId         String           @map("user_id")
  academyId      String?          @map("academy_id")
  type           NotificationType @default(INFO)
  title          String
  message        String
  link           String?
  relatedId      String?          @map("related_id")
  isRead         Boolean          @default(false) @map("is_read")
  createdAt      DateTime         @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id])
  academy Academy? @relation(fields: [academyId], references: [id])

  @@index([userId])
  @@index([academyId])
  @@index([createdAt])
  @@map("notifications")
}

/// 19. 공지사항
model Announcement {
  id          String             @id @default(uuid())
  academyId   String             @map("academy_id")
  authorId    String             @map("author_id")
  classId     String?            @map("class_id")
  title       String
  content     String
  target      AnnouncementTarget @default(ALL_STUDENTS)
  isPublished Boolean            @default(true) @map("is_published")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  academy Academy @relation(fields: [academyId], references: [id])
  author  User    @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  class   Class?  @relation(fields: [classId], references: [id])

  @@index([academyId])
  @@map("announcements")
}

/// 14. 출석
model Attendance {
  id        String           @id @default(uuid())
  studentId String           @map("student_id")
  classId   String           @map("class_id")
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  note      String?
  createdAt DateTime         @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, date])
  @@index([studentId])
  @@index([classId])
  @@map("attendance")
}

/// 15. 배지
model Badge {
  id          String     @id @default(uuid())
  academyId   String?    @map("academy_id")
  code        BadgeType? @unique
  name        String
  description String?
  iconUrl     String?    @map("icon_url")
  criteria    Json?
  createdAt   DateTime   @default(now()) @map("created_at")

  academy  Academy?      @relation(fields: [academyId], references: [id])
  earnings BadgeEarning[]

  @@map("badges")
}

/// 16-a. 학습 스트릭
model StudentStreak {
  id               String    @id @default(uuid())
  studentId        String    @unique @map("student_id")
  currentStreak    Int       @default(0) @map("current_streak")
  longestStreak    Int       @default(0) @map("longest_streak")
  lastActivityDate DateTime? @map("last_activity_date")
  totalDays        Int       @default(0) @map("total_days")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])

  @@map("student_streaks")
}

/// 16-b. 오늘의 미션
model DailyMission {
  id               String    @id @default(uuid())
  studentId        String    @map("student_id")
  missionDate      DateTime  @map("mission_date")
  questionIds      Json      @map("question_ids")
  domainFocus      String?   @map("domain_focus")
  isCompleted      Boolean   @default(false) @map("is_completed")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  status           String    @default("GENERATED")
  missionsJson     Json?     @map("missions_json")
  totalMissions    Int       @default(0) @map("total_missions")
  completedMissions Int      @default(0) @map("completed_missions")
  startedAt        DateTime? @map("started_at")
  xpEarned         Int       @default(0) @map("xp_earned")
  streakCounted    Boolean   @default(false) @map("streak_counted")

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, missionDate])
  @@index([status])
  @@map("daily_missions")
}

/// 16-c. 학생 XP 기록
model StudentXp {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount    Int
  source    String
  sourceId  String?  @map("source_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([studentId])
  @@index([createdAt])
  @@map("student_xp")
}

model BadgeEarning {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  badgeId   String   @map("badge_id")
  earnedAt  DateTime @default(now()) @map("earned_at")

  student Student @relation(fields: [studentId], references: [id])
  badge   Badge   @relation(fields: [badgeId], references: [id])

  @@unique([studentId, badgeId])
  @@map("badge_earnings")
}

/// 17. 수강 등록
model Enrollment {
  id         String   @id @default(uuid())
  studentId  String   @map("student_id")
  classId    String   @map("class_id")
  academyId  String   @map("academy_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])
  academy Academy @relation(fields: [academyId], references: [id])

  @@unique([studentId, classId])
  @@index([academyId])
  @@map("enrollments")
}

/// 17. 구독 이력
model Subscription {
  id            String             @id @default(uuid())
  academyId     String             @map("academy_id")
  plan          PlanType
  amount        Int
  period        SubscriptionPeriod
  startedAt     DateTime           @map("started_at")
  expiresAt     DateTime           @map("expires_at")
  paymentMethod String?            @map("payment_method")
  paymentRef    String?            @map("payment_ref")
  status        PaymentStatus      @default(PENDING)
  createdAt     DateTime           @default(now()) @map("created_at")

  academy Academy @relation(fields: [academyId], references: [id])

  @@map("subscriptions")
}

/// 20. 학습공간 연습 로그
model PracticeLog {
  id           String          @id @default(uuid())
  studentId    String          @map("student_id")
  mode         String          // "adaptive" | "domain" | "review"
  domain       QuestionDomain?
  totalCount   Int             @map("total_count")
  correctCount Int             @map("correct_count")
  score        Int
  resultsJson  Json            @map("results_json")
  createdAt    DateTime        @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([createdAt])
  @@map("practice_logs")
}

/// 18. 요금제 정의
model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String   @unique
  displayName  String   @map("display_name")
  monthlyPrice Int      @map("monthly_price")
  yearlyPrice  Int      @map("yearly_price")
  maxStudents  Int      @map("max_students")
  maxTeachers  Int      @map("max_teachers")
  featuresJson Json     @map("features_json")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("subscription_plans")
}
